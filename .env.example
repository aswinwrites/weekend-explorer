# ─── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings > API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── App ───────────────────────────────────────────────────────────────────────
# Full URL of your deployment (no trailing slash)
NEXT_PUBLIC_APP_URL=https://weekend-explorer.vercel.app

# ─── PostHog ───────────────────────────────────────────────────────────────────
# Project Settings > Project API key in your PostHog dashboard
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Use https://eu.posthog.com if you chose the EU cloud region
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
